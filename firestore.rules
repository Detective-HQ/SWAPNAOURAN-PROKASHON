rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict user-ownership model for all personal data (carts, orders, profiles)
     * while allowing public read access to the bookstore's catalog (books, ebooks, publishers). 
     * 
     * DATA STRUCTURE:
     * - Public catalog data is stored in top-level collections: /books, /ebooks, /publishers.
     * - User-specific data is strictly nested under /users/{userId} to ensure path-based isolation.
     * 
     * KEY SECURITY DECISIONS:
     * - Public Listing: Books, Ebooks, and Publishers are publicly listable to allow browsing without authentication.
     * - User Listing: User profiles and their subcollections are never publicly listable; users can only list their own data.
     * - Write Protection: Catalog data is read-only for the client application. Only user-owned data can be modified.
     * - Relational Integrity: On creation of user-scoped documents, the document's internal ID or ownership field must 
     *   match the authenticated user's ID and the path.
     * 
     * DENORMALIZATION FOR AUTHORIZATION:
     * This ruleset utilizes path-based authorization for user data, which is the most efficient method in Firestore.
     * For catalog data, no extra reads (get calls) are required as the collections are inherently public.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Combines ownership check with document existence for updates and deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the user's root profile document.
     * @path /users/{userId}
     * @allow Authenticated user matching the ID (get, list, create, update).
     * @deny Any other user or unauthenticated request.
     * @principle Ownership-based access and self-creation.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Publicly readable catalog of publishers.
     * @path /publishers/{publisherId}
     * @allow Anyone (get, list).
     * @deny Any write operations from the client.
     * @principle Publicly accessible data with restricted writes.
     */
    match /publishers/{publisherId} {
      allow get, list: if true;
      allow create, update, delete: if false;

      /**
       * @description Images for the 'Photo Time' gallery of a publisher.
       * @path /publishers/{publisherId}/galleryImages/{imageId}
       * @allow Anyone (get, list).
       * @deny Any write operations from the client.
       * @principle Hierarchical public access.
       */
      match /galleryImages/{imageId} {
        allow get, list: if true;
        allow create, update, delete: if false;
      }
    }

    /**
     * @description Publicly readable catalog of physical books.
     * @path /books/{bookId}
     * @allow Anyone (get, list).
     * @deny Any write operations from the client.
     * @principle Publicly accessible data with restricted writes.
     */
    match /books/{bookId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Publicly readable catalog of digital ebooks.
     * @path /ebooks/{ebookId}
     * @allow Anyone (get, list).
     * @deny Any write operations from the client.
     * @principle Publicly accessible data with restricted writes.
     */
    match /ebooks/{ebookId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description A user's active shopping cart.
     * @path /users/{userId}/cart
     * @allow The user who owns the cart (get, list, create, update, delete).
     * @deny Any other user.
     * @principle Path-based ownership for private data trees.
     */
    match /users/{userId}/cart {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Individual items within a user's shopping cart.
     * @path /users/{userId}/cartItems/{cartItemId}
     * @allow The user who owns the cart (get, list, create, update, delete).
     * @deny Any other user.
     * @principle Path-based ownership and relational integrity.
     */
    match /users/{userId}/cartItems/{cartItemId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == cartItemId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Records of a user's completed orders.
     * @path /users/{userId}/orders/{orderId}
     * @allow The user who placed the order (get, list, create).
     * @deny Updates or deletions (orders are generally immutable once placed).
     * @principle Immutable transactional records under user ownership.
     */
    match /users/{userId}/orders/{orderId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update, delete: if false;
    }

    /**
     * @description Items associated with a specific completed order.
     * @path /users/{userId}/orderItems/{orderItemId}
     * @allow The user who owns the order (get, list, create).
     * @deny Updates or deletions.
     * @principle Path-based ownership for immutable order history.
     */
    match /users/{userId}/orderItems/{orderItemId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == orderItemId;
      allow update, delete: if false;
    }

    /**
     * @description Entitlement records for viewing purchased ebooks.
     * @path /users/{userId}/ebookAccess/{userEbookAccessId}
     * @allow The user who purchased the access (get, list).
     * @deny Direct modification by the client (usually managed by backend/fulfillment).
     * @principle User-specific access control for digital content.
     */
    match /users/{userId}/ebookAccess/{userEbookAccessId} {
      allow get, list: if isOwner(userId);
      allow create, update, delete: if false;
    }

    /**
     * @description Personalized book recommendations generated for the user.
     * @path /users/{userId}/recommendations/{recommendationId}
     * @allow The user receiving the recommendation (get, list).
     * @deny Modification or deletion by the client.
     * @principle Read-only access to user-specific generated content.
     */
    match /users/{userId}/recommendations/{recommendationId} {
      allow get, list: if isOwner(userId);
      allow create, update, delete: if false;
    }
  }
}